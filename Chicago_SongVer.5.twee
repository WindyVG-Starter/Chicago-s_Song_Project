:: StoryScript [script]
/*JavaScript is for music and Stylesheet is for visual*/





:: StoryStylesheet [stylesheet]
tw-sidebar 
{
  display: none; 
}

tw-story[tags~="Menu"] 
{
  background-image:url("https://cdn.pixabay.com/photo/2016/02/29/23/06/chicago-1229463_1280.jpg");
  background-size:cover; 
}
.text_box {
  background-color: rgba(0, 0, 0, 0.9);
  
  display: flex;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 20px;
  font-size: 24px;
  border-radius: 10px;
}
.start-button 
{ 
  display: flex; /*This helps makes the text inside of the box easily aligned and positioned*/
  background-color: rgba(255, 255, 255, 0.9); /*The color of the box*/
  border: 3px solid white; /*This is the boarder line*/
  
  justify-content: center; /*Works along with display: flex, helps control the horizontally side to side*/
  align-items: center;  /*Works along with display: flex, helps control the up-and-down direction*/
  text-align: center; /*Helps with the text inside horizontal alignment*/
  padding: 20px; /*It's basically ensure that there are 20 space between the text and boarder line*/
  font-size: 24px; /*The size of the text*/
  border-radius: 12px; /*corners of your box rounded instead of sharp.*/
  
  transition: 0.3s;
}

.start-button:hover /*When a player hovers thge button, the background becomes lighter*/
{
  background-color: Black;
  cursor: pointer;
   transform: scale(1.05);
}
.credits-button
{  
  display: flex;
  background-color: rgba(255, 255, 255, 0.9);
  border: 3px solid white;

  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 20px;
  font-size: 24px;
  border-radius: 12px;
  
  transition: 0.3s;
}

.button-row 
{
  display: flex;
  justify-content: center;  /* centers the group */
  gap: 20px;                /* space between buttons */
  margin-top: 30px;
}


.credits-button:hover
{
  background-color: Black;
  cursor: pointer;
   transform: scale(1.05);
}




/*The button for returning back to the menu*/
tw-hook[name="returnbtn"] tw-link 
{
  display: flex;
  background-color: rgba(255, 255, 255, 0.9);
  border: 3px solid white;
  
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 20px;
  font-size: 24px;
  border-radius: 12px;
  
  transition: 0.3s;
  
  font-size: 25px;
  font-weight: bold;
  
  transition: 0.3s;
}

tw-hook[name="returnbtn"] tw-link:hover {
  background-color: Black;
  cursor: pointer;
  transform: scale(1.05);
}






/* This part is for the hospital level*/
tw-story[tags~="Hospital"] 
{
  background-image:url("https://cdn.pixabay.com/photo/2015/09/03/17/49/hospital-921034_1280.jpg");
  background-size:cover;
  animation: fadein 100s;
}

.Random_doctors_and_nurses {
  margin: 10px 0;
  flex-direction: column; /* stack vertically */
  gap: 1px;
  
  display: flex;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 20px;
  font-size: 24px;
  border-radius: 12px;

  background-color: rgba(0, 0, 0, 0.9);
  border-radius: 12px;

  color: white;
  font-family: Arial, sans-serif;
  font-size: 20px;
  line-height: 1.6;
  text-align: left;

  box-shadow: 0 10px 30px rgba(0,0,0,0.6);
}

/*Thi is the text for your thoughts that belong to the first passage*/
.SelfBubble {
  display: flex;
  justify-content: flex-start;   /* horizontal alignment */
  align-items: flex-start;       /* vertical alignment */
  text-align: left;
  
  /*The Text*/
  font-family: Trebuchet MS;
  font-size: 25px;

  /*The overall look of the box*/	
  background-color: rgba(0, 0, 0, 0.9);
  border-radius: 0px;

  line-height: 1.6;

  padding: 15px;  /* THIS is key */
  
}

/*The button for the first passage*/
.next-button 
{
  display: flex;
  background-color: rgba(255, 255, 255, 0.9);
  border: 3px solid white;

  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 20px;
  font-size: 24px;
  border-radius: 12px;
  
  transition: 0.3s;

}

.next-button:hover
{
  background-color: Black;
  cursor: pointer;
   transform: scale(1.05);
}






/* This part is for the hospital level part 2*/
tw-story[tags~="Nexthospital"]::before   /*First layer*/
{
  content: "";
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1; /* Puts it behind everything */
  
  background-image:url("https://cdn.pixabay.com/photo/2015/09/03/17/49/hospital-921034_1280.jpg");
  background-size:cover;
  
  filter: brightness(0.3);
  
  animation: fadein 100s;
}


/* This ensures the story container itself is transparent 
   so we can see the background behind it */
tw-story[tags~="Nexthospital"] {
  background: transparent;
}

.dialogue {

  /*Determine the shapes, size where it sits in screen*/
  display: block; /*A solid shape*/  
  max-width: 500px; 
  margin: 10px auto;
  padding: 10px 50px;

  background-color: rgba(0, 0, 0, 0.85); /* Slightly transparent black */
  border-radius: 0px;

  color: white;
  font-family: "Times New Roman", serif;
  font-size: 20px;
  line-height: 1.6;
  text-align: left;

  /*This forces the text box to be in front*/
  position: relative;   
  z-index: 999;        

}




/*The first choices*/
.Choice1button
{
  display: inline-block;
  margin: 40px auto;
  width: 140px;
  
  text-align: center;/* Centers the text inside the box */
  padding: 15px;
  border: 2px solid white;
  background-color: white; /* Subtle transparent white */
  border-radius: 10px;
  transition: all 0.2s; /* Smooth hover effect */
}

.Choice1button:hover
{
  background-color: Black;
  cursor: pointer;
   transform: scale(1.05);
}

.Choice2button
{
  display: inline-block;
  margin: 40px auto;
  width: 140px;
  
  text-align: center;/* Centers the text inside the box */
  padding: 15px;
  border: 2px solid white;
  background-color: white; /* Subtle transparent white */
  border-radius: 10px;
  transition: all 0.2s; /* Smooth hover effect */
}



.Choice2button:hover
{
  background-color: black;
  cursor: pointer;
   transform: scale(1.05);
}

.button-row 
{
  display: flex;
  justify-content: center;  /*It seems to put these on the bottom for it to actually work*/
  margin-top: 30px;
}






/*Nexthospital page*/
tw-story[tags~="Choice12"]::before   /*First layer*/
{
  content: "";
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1; /* Puts it behind everything */
  
